-- // [[ CORE ENGINE FUNCTIONS: STATE MANAGEMENT ]] // --

local function Internal_RevertPlayer(targetPlayerInstance)
    local SavedState = EngineState.SessionData[targetPlayerInstance]
    
    if SavedState and targetPlayerInstance.Character then
        local TargetPart = targetPlayerInstance.Character:FindFirstChild(SavedState.PartName)
        
        if TargetPart then
            -- Restoring Physical Properties
            TargetPart.Size = SavedState.OriginalSize
            TargetPart.Transparency = SavedState.OriginalTransparency
            TargetPart.CanCollide = SavedState.OriginalCanCollide
            TargetPart.Massless = SavedState.OriginalMassless
            TargetPart.CustomPhysicalProperties = nil
            
            -- Restoring Decal Visuals (Specific for Head)
            if SavedState.PartName == "Head" then
                for _, Object in ipairs(SavedState.OriginalDecals or {}) do
                    if Object and Object.Instance then
                        Object.Instance.Transparency = 0
                    end
                end
            end
        end
    end
    -- Purge Cache
    EngineState.SessionData[targetPlayerInstance] = nil
end

local function Internal_ApplySavage(targetPlayerInstance)
    if targetPlayerInstance == ClientPlayer then return end
    if not targetPlayerInstance.Character then return end
    if not EngineState.GlobalEnabled then return end
    
    local CharacterModel = targetPlayerInstance.Character
    local TargetPart = CharacterModel:FindFirstChild(EngineState.TargetComponent)
    local HumanoidComponent = CharacterModel:FindFirstChildOfClass("Humanoid")
    
    if TargetPart and HumanoidComponent and HumanoidComponent.Health > 0 then
        -- Backup Original Attributes if entry doesn't exist
        if not EngineState.SessionData[targetPlayerInstance] then
            local DecalReferenceList = {}
            if EngineState.TargetComponent == "Head" then
                for _, Child in ipairs(TargetPart:GetChildren()) do
                    if Child:IsA("Decal") then
                        table.insert(DecalReferenceList, {Instance = Child})
                    end
                end
            end
            
            EngineState.SessionData[targetPlayerInstance] = {
                PartName = EngineState.TargetComponent,
                OriginalSize = TargetPart.Size,
                OriginalTransparency = TargetPart.Transparency,
                OriginalCanCollide = TargetPart.CanCollide,
                OriginalMassless = TargetPart.Massless,
                OriginalDecals = DecalReferenceList
            }
        end
        
        -- Executing Modifications (Massless Hitbox Engine)
        TargetPart.Size = EngineState.ScaleFactor
        TargetPart.Transparency = EngineState.TransparencyIndex
        TargetPart.CanCollide = false
        TargetPart.Massless = true
        TargetPart.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)
        
        -- Clean Visual Implementation
        if EngineState.TargetComponent == "Head" then
            for _, ChildObject in ipairs(TargetPart:GetChildren()) do
                if ChildObject:IsA("Decal") then
                    ChildObject.Transparency = 1
                end
            end
        end
    end
end

-- // [[ SYSTEM CONTROLLER: MODE SWITCHING ]] // --

local function Global_SwitchMode(ModeIdentifier, PartIdentifier, ScaleValue)
    -- Visual Feedback for Console
    print("[UBY GOAT LOG] : Attempting Switch to " .. ModeIdentifier)
    
    if EngineState.CurrentExecution == ModeIdentifier then
        -- DEACTIVATION SEQUENCE
        EngineState.GlobalEnabled = false
        EngineState.CurrentExecution = "NONE"
        for _, CurrentTarget in ipairs(PlayersService:GetPlayers()) do
            Internal_RevertPlayer(CurrentTarget)
        end
    else
        -- RE-INITIALIZATION SEQUENCE
        for _, CurrentTarget in ipairs(PlayersService:GetPlayers()) do
            Internal_RevertPlayer(CurrentTarget)
        end
        EngineState.GlobalEnabled = true
        EngineState.CurrentExecution = ModeIdentifier
        EngineState.TargetComponent = PartIdentifier
        EngineState.ScaleFactor = Vector3.new(ScaleValue, ScaleValue, ScaleValue)
    end
end

