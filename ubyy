local function applyHead(p)
    if p == player or not p.Character or not state.enabled then return end
    local head = p.Character:FindFirstChild("Head")
    local hum = p.Character:FindFirstChildOfClass("Humanoid")
    if not head or not hum or hum.Health <= 0 then return end
    if not state.data[p] then state.data[p] = { size = head.Size, trans = head.Transparency } end

    head.Size = state.currentScale
    head.Transparency = 1 -- Clean Mode
    head.Massless = true
    head.CanCollide = false
    head.CustomPhysicalProperties = PhysicalProperties.new(0,0,0,0,0)
    for _, v in pairs(head:GetChildren()) do if v:IsA("Decal") then v.Transparency = 1 end end
end

