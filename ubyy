_G.HitboxStatus = false
_G.LinzStatus = false

-- Fungsi Toggle Yahayuk (Shortcut L)
local function toggleYahayuk()
    _G.HitboxStatus = not _G.HitboxStatus
    _G.LinzStatus = false -- Matikan mode satunya biar ga bentrok
    local btn = main:FindFirstChild("YahayukBtn")
    local btnLinz = main:FindFirstChild("LinzBtn")
    
    if _G.HitboxStatus then
        if btn then btn.BackgroundColor3 = Color3.fromRGB(150, 230, 180) btn.Text = "YAHAYUK: ON" end
        if btnLinz then btnLinz.BackgroundColor3 = Color3.fromRGB(255, 160, 200) btnLinz.Text = "LINZ BAU BAWANG" end
    else
        if btn then btn.BackgroundColor3 = Color3.fromRGB(255, 120, 180) btn.Text = "AUTO WALK YAHAYUK" end
        for _, v in pairs(game:GetService('Players'):GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                pcall(function() v.Character.HumanoidRootPart.Size = Vector3.new(2,2,2) end)
            end
        end
    end
end

-- Fungsi Toggle Linz (Shortcut N)
local function toggleLinz()
    _G.LinzStatus = not _G.LinzStatus
    _G.HitboxStatus = false -- Matikan mode satunya biar ga bentrok
    local btn = main:FindFirstChild("YahayukBtn")
    local btnLinz = main:FindFirstChild("LinzBtn")

    if _G.LinzStatus then
        if btnLinz then btnLinz.BackgroundColor3 = Color3.fromRGB(150, 230, 180) btnLinz.Text = "LINZ: ON (SIZE 12)" end
        if btn then btn.BackgroundColor3 = Color3.fromRGB(255, 120, 180) btn.Text = "AUTO WALK YAHAYUK" end
    else
        if btnLinz then btnLinz.BackgroundColor3 = Color3.fromRGB(255, 160, 200) btnLinz.Text = "LINZ BAU BAWANG" end
        for _, v in pairs(game:GetService('Players'):GetPlayers()) do
            if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
                pcall(function() v.Character.HumanoidRootPart.Size = Vector3.new(2,2,2) end)
            end
        end
    end
end

