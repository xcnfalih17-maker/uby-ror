-- -- [ UTILITY FUNCTIONS ] -- --
local function GetHead(character)
    return character and character:FindFirstChild("Head")
end

local function GetHumanoid(character)
    return character and character:FindFirstChildOfClass("Humanoid")
end

-- -- [ CORE ENGINE: APPLY & REVERT ] -- --
local function ApplyHitbox(targetPlayer)
    if targetPlayer == LocalPlayer or not targetPlayer.Character then return end
    
    local head = GetHead(targetPlayer.Character)
    local humanoid = GetHumanoid(targetPlayer.Character)
    
    if not head or not humanoid or humanoid.Health <= 0 then return end

    -- Save Original State (Biar bisa balik normal)
    if not State.DataStore[targetPlayer] then
        local decals = {}
        for _, obj in ipairs(head:GetChildren()) do
            if obj:IsA("Decal") then
                table.insert(decals, {Instance = obj, Parent = obj.Parent})
            end
        end
        State.DataStore[targetPlayer] = {
            Size = head.Size,
            Transparency = head.Transparency,
            CanCollide = head.CanCollide,
            Massless = head.Massless,
            Decals = decals
        }
    end

    -- Apply Savage Mod
    head.Size = State.HitboxSize
    head.Transparency = State.Transparency
    head.CanCollide = false
    head.Massless = true -- ANTI STUCK
    head.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0) -- BIAR LICIN

    -- Hide Face/Decals
    for _, obj in ipairs(head:GetChildren()) do
        if obj:IsA("Decal") then
            obj.Transparency = 1
        end
    end
end

local function RevertHitbox(targetPlayer)
    local original = State.DataStore[targetPlayer]
    if not original or not targetPlayer.Character then return end
    
    local head = GetHead(targetPlayer.Character)
    if head then
        head.Size = original.Size
        head.Transparency = original.Transparency
        head.CanCollide = original.CanCollide
        head.Massless = original.Massless
        head.CustomPhysicalProperties = nil
        
        for _, d in ipairs(original.Decals) do
            if d.Instance then d.Instance.Transparency = 0 end
        end
    end
    State.DataStore[targetPlayer] = nil
end

