-- -- 2. ANTI-STUCK ENGINE -- --
_G.UBY_ENGINE = _G.UBY_ENGINE or {
    enabled = false,
    currentScale = Vector3.new(1,1,1),
    data = {}
}
local state = _G.UBY_ENGINE

local function applyHead(p)
    if p == player or not state.enabled or not p.Character then return end
    local head = p.Character:FindFirstChild("Head")
    local hum = p.Character:FindFirstChildOfClass("Humanoid")
    if not head or not hum or hum.Health <= 0 then return end

    if not state.data[p] then
        state.data[p] = { size = head.Size, transparency = head.Transparency }
    end

    -- -- MODIFIKASI AGAR TIDAK STUCK -- --
    head.Size = state.currentScale
    head.Transparency = 1        -- Clean Mode (Gak kelihatan)
    head.CanCollide = false     -- Biar gak nabrak tembok/lantai
    head.Massless = true        -- BIAR GAK BERAT (Gak bikin stuck)
    
    -- Menghapus friction (gesekan) biar musuh lancar jalannya
    head.CustomPhysicalProperties = PhysicalProperties.new(0, 0, 0, 0, 0)

    -- Hapus muka musuh biar beneran clean
    for _, v in pairs(head:GetChildren()) do
        if v:IsA("Decal") then v.Transparency = 1 end
    end
end

local function revertHead(p)
    local saved = state.data[p]
    if saved and p.Character and p.Character:FindFirstChild("Head") then
        local head = p.Character.Head
        head.Size = saved.size
        head.Transparency = saved.transparency
        head.CanCollide = true
        head.Massless = false
        for _, v in pairs(head:GetChildren()) do
            if v:IsA("Decal") then v.Transparency = 0 end
        end
    end
    state.data[p] = nil
end

