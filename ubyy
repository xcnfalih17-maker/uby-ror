local function styleBtn(btn, pos, color, text)
    btn.Parent = MainFrame
    btn.Size = UDim2.new(0, 160, 0, 35)
    btn.Position = pos
    btn.BackgroundColor3 = color
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Gotham
    btn.TextSize = 14
    btn.BorderSizePixel = 0
end

styleBtn(RecordBtn, UDim2.new(0.1, 0, 0.2, 0), Color3.fromRGB(200, 50, 50), "Record Path")
styleBtn(PlayBtn, UDim2.new(0.1, 0, 0.42, 0), Color3.fromRGB(50, 150, 50), "Play Path")
styleBtn(ClearBtn, UDim2.new(0.1, 0, 0.64, 0), Color3.fromRGB(70, 70, 70), "Clear Data")

-- LOGIC --
local pathData = {}
local isRecording = false
local isPlaying = false

-- Fungsi Hide Menu
CloseBtn.MouseButton1Click:Connect(function()
    MainFrame.Visible = false
    print("UBY MENU: Tersembunyi! Tekan 'Insert' buat munculin lagi.")
end)

-- Munculin lagi pake tombol Insert di Keyboard
local UserInputService = game:GetService("UserInputService")
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if not gameProcessed and input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
    end
end)

-- Fungsi Record (Bisa record Lompat juga sekarang)
RecordBtn.MouseButton1Click:Connect(function()
    if isPlaying then return end
    isRecording = not isRecording
    
    if isRecording then
        pathData = {}
        RecordBtn.Text = "STOP RECORD"
        StatusLabel.Text = "Recording... (Jump Included)"
        task.spawn(function()
            while isRecording do
                local char = game.Players.LocalPlayer.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                local hum = char and char:FindFirstChild("Humanoid")
                if root and hum then
                    table.insert(pathData, {
                        pos = root.Position,
                        jumping = (hum.FloorMaterial == Enum.Material.Air)
                    })
                end
                task.wait(0.15)
            end
        end)
    else
        RecordBtn.Text = "Record Path"
        StatusLabel.Text = "Saved: "..#pathData.." pts"
    end
end)

-- Fungsi Play
PlayBtn.MouseButton1Click:Connect(function()
    if isRecording or #pathData == 0 then return end
    isPlaying = not isPlaying
    
    if isPlaying then
        PlayBtn.Text = "STOP PLAY"
        StatusLabel.Text = "Slebew Walking..."
        task.spawn(function()
            while isPlaying do
                local char = game.Players.LocalPlayer.Character
                local hum = char and char:FindFirstChild("Humanoid")
                if hum then
                    for i, data in ipairs(pathData) do
                        if not isPlaying then break end
                        if data.jumping then hum.Jump = true end
                        hum:MoveTo(data.pos)
                        hum.MoveToFinished:Wait()
                    end
                end
                task.wait(0.1)
            end
        end)
    else
        PlayBtn.Text = "Play Path"
        StatusLabel.Text = "Status: Stopped"
    end
end)

-- Clear Data
ClearBtn.MouseButton1Click:Connect(function()
    pathData = {}
    isRecording = false
    isPlaying = false
    StatusLabel.Text = "Data Cleared!"
end)
